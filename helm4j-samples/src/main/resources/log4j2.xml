<?xml version="1.0" encoding="UTF-8"?>
<!--
  Sample-suite logging: SLF4J narration is routed here (via log4j-slf4j2-impl); demonstrated results
  print to System.out via SampleOutput. Both go to the console so a run reads as one story.
-->
<Configuration status="WARN">
  <Appenders>
    <Console name="Console" target="SYSTEM_OUT">
      <PatternLayout pattern="%d{HH:mm:ss.SSS} %-5level %logger{1} - %msg%n"/>
    </Console>
  </Appenders>
  <Loggers>
    <!-- Sample narration. -->
    <Logger name="dev.nthings.helm4j.samples" level="INFO"/>
    <!--
      The SDK's own FFM bridge and gateways log at DEBUG. Raise this logger to DEBUG to watch the
      native crossings and per-operation calls under the hood:
        <Logger name="dev.nthings.helm4j.runtime.ffm" level="DEBUG"/>
    -->
    <Logger name="dev.nthings.helm4j.runtime.ffm" level="INFO"/>
    <Root level="INFO">
      <AppenderRef ref="Console"/>
    </Root>
  </Loggers>
</Configuration>
